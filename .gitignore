# ── Environnements virtuels ───────────────────────────────────────────────
venv/
.venv/
env/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Modèles et poids (générés par train.py) ───────────────────────────────
mask_generator/weights/*.pth.tar
mask_generator/weights/*.pth

# ── Dataset d'entraînement (trop lourd pour git) ─────────────────────────
mask_generator/DatasetSimuator/

# ── Images générées / captures caméra ────────────────────────────────────
mask_generator/image/
mask_generator/datasets/

# ── Données d'entraînement du simulateur (générées par record) ───────────
racing_simulator/datasets/*.csv

# ── Wheels Python (trop lourds, téléchargés par setup.sh) ────────────────
*.whl

# ── Divers ────────────────────────────────────────────────────────────────
.DS_Store
*.log
